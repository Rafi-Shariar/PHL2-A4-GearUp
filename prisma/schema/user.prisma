model User {
    userId        String       @id @default(uuid())
    email         String       @unique
    name          String
    password      String
    phoneNumber   String
    role          Role         @default(CUSTOMER)
    address       String?
    photoURL      String?
    accountStatus ActiveStatus @default(ACTIVE)

    gearItems GearItems[]
    orders    RentalOrders[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}
